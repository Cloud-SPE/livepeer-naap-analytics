          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "WITH ens AS (SELECT orch_address AS addr, name AS ens_name FROM naap.api_latest_orchestrator_state),\nactive_counts AS (\n    SELECT orch_address AS addr, countDistinct(stream_id) AS active_streams\n    FROM naap.operational_stream_status_samples\n    WHERE sample_ts >= now() - INTERVAL 15 MINUTE AND is_attributed = 1 AND orch_address != ''\n    AND ('${org:csv}' = '__all' OR '${org:csv}' = '' OR has(splitByChar(',', '${org:csv}'), org))\n    GROUP BY addr\n)\nSELECT a.addr AS \"Orchestrator Address\",\n    if(ifNull(ens.ens_name, '') != '' AND NOT startsWith(lower(ens.ens_name), '0x'), ens.ens_name, a.addr) AS \"Orchestrator ENS\",\n    toUInt64(a.active_streams) AS \"Active Streams\"\nFROM active_counts a\nLEFT JOIN ens e ON e.addr = a.addr\nWHERE ('${orchestrator:csv}' = '__all' OR '${orchestrator:csv}' = '' OR has(splitByChar(',', '${orchestrator:csv}'), a.addr))\nORDER BY \"Active Streams\" DESC, \"Orchestrator Address\" ASC\nLIMIT 12",
          "refId": "A"
        }
      ],
      "title": "Streams by Orchestrator (15m; includes zero-active)",
