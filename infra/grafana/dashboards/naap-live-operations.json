          "rawSql": "SELECT toStartOfInterval(event_ts, INTERVAL 1 MINUTE) AS time,\n    event_type AS stage,\n    count() AS events_per_minute\nFROM naap.accepted_raw_events\nWHERE $__timeFilter(event_ts)\nAND ('${org:csv}' = '__all' OR '${org:csv}' = '' OR has(splitByChar(',', '${org:csv}'), org))\nGROUP BY time, stage\nORDER BY time",
          "refId": "A"
