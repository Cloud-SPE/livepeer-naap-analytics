      "id": 2,
      "options": {
        "cellHeight": "sm",
        "showHeader": true,
        "sortBy": [
          {
            "desc": false,
            "displayName": "Last Sample Age (s)"
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "${clickhouse_ds}"
          },
          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "WITH ens AS (SELECT orch_address AS addr, name AS ens_name FROM naap.api_latest_orchestrator_state),\nlatest_streams AS (\n    SELECT stream_id,\n        max(sample_ts) AS sample_ts,\n        argMax(org, sample_ts) AS org,\n        argMax(gateway, sample_ts) AS gateway,\n        argMax(orch_address, sample_ts) AS orch_address,\n        argMax(pipeline, sample_ts) AS pipeline,\n        argMax(state, sample_ts) AS state,\n        argMax(output_fps, sample_ts) AS output_fps\n    FROM naap.operational_stream_status_samples\n    WHERE sample_ts >= now() - INTERVAL 90 SECOND\n    GROUP BY stream_id\n)\nSELECT s.stream_id AS \"Stream ID\",\n    if(ifNull(ens.ens_name, '') != '' AND NOT startsWith(lower(ens.ens_name), '0x'), ens.ens_name, s.orch_address) AS \"Orchestrator ENS\",\n    ifNull(s.pipeline, 'unknown') AS \"Pipeline\",\n    s.gateway AS \"Gateway\",\n    round(ifNull(s.output_fps, 0), 2) AS \"FPS\",\n    s.state AS \"State\",\n    toUInt64(greatest(dateDiff('second', s.sample_ts, now()), 0)) AS \"Last Sample Age (s)\"\nFROM latest_streams s\nLEFT JOIN ens e ON e.addr = s.orch_address\nWHERE ('${org:csv}' = '__all' OR '${org:csv}' = '' OR has(splitByChar(',', '${org:csv}'), s.org))\nAND ('${orchestrator:csv}' = '__all' OR '${orchestrator:csv}' = '' OR has(splitByChar(',', '${orchestrator:csv}'), s.orch_address))\nORDER BY \"Last Sample Age (s)\" ASC\nLIMIT 100",
          "refId": "A"
        }
      ],
      "title": "Current Known Live Streams",
      "type": "table"
    },
