          "editorType": "sql",
          "format": 1,
          "queryType": "sql",
          "rawSql": "WITH raw AS (SELECT max(ingested_at) AS raw_max FROM naap.accepted_raw_events WHERE event_type IN ('stream_trace', 'ai_stream_status', 'ai_stream_events', 'network_capabilities') AND ('${org:csv}' = '__all' OR '${org:csv}' = '' OR has(splitByChar(',', '${org:csv}'), org))), wm AS (SELECT max(last_ingested_at) AS wm_max FROM naap.resolver_runtime_state FINAL) SELECT toFloat64(greatest(dateDiff('second', ifNull(wm_max, raw_max), raw_max), 0)) AS value FROM raw CROSS JOIN wm",
          "refId": "A"
        }
