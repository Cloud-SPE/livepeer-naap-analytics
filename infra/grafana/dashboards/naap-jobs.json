          "editorType": "sql",
          "format": 2,
          "queryType": "sql",
          "rawSql": "SELECT ifNull(canonical_pipeline, capability_name) AS pipeline_id, if(capability_family = 'byoc', 'byoc', 'ai-batch') AS job_type, sum(job_count) AS total_jobs, toFloat64(sum(success_count)) / nullIf(toFloat64(sum(job_count)), 0) AS success_rate, round(toFloat64(sum(duration_ms_sum)) / nullIf(toFloat64(sum(job_count)), 0), 1) AS avg_duration_ms FROM naap.api_hourly_request_demand WHERE $__timeFilter(window_start) AND ('${org:csv}' = '__all' OR '${org:csv}' = '' OR has(splitByChar(',', '${org:csv}'), org)) AND ifNull(canonical_pipeline, capability_name) != '' GROUP BY pipeline_id, job_type ORDER BY total_jobs DESC LIMIT 20",
          "refId": "A"
        }
