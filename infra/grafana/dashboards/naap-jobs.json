          "editorType": "sql",
          "format": 2,
          "queryType": "sql",
          "rawSql": "WITH source_counts AS (\n  SELECT 'ai-batch' AS job_type, count() AS source_jobs\n  FROM naap.normalized_ai_batch_job FINAL\n  WHERE subtype = 'ai_batch_request_completed'\n    AND request_id != ''\n    AND $__timeFilter(event_ts)\n    AND ('${org:csv}' = '__all' OR '${org:csv}' = '' OR has(splitByChar(',', '${org:csv}'), org))\n  UNION ALL\n  SELECT 'byoc' AS job_type, count() AS source_jobs\n  FROM naap.normalized_byoc_job FINAL\n  WHERE subtype = 'job_gateway_completed'\n    AND $__timeFilter(event_ts)\n    AND ('${org:csv}' = '__all' OR '${org:csv}' = '' OR has(splitByChar(',', '${org:csv}'), org))\n), canonical_counts AS (\n  SELECT 'ai-batch' AS job_type, count() AS canonical_jobs\n  FROM naap.canonical_ai_batch_jobs\n  WHERE $__timeFilter(completed_at)\n    AND ('${org:csv}' = '__all' OR '${org:csv}' = '' OR has(splitByChar(',', '${org:csv}'), org))\n  UNION ALL\n  SELECT 'byoc' AS job_type, count() AS canonical_jobs\n  FROM naap.canonical_byoc_jobs\n  WHERE $__timeFilter(completed_at)\n    AND ('${org:csv}' = '__all' OR '${org:csv}' = '' OR has(splitByChar(',', '${org:csv}'), org))\n)\nSELECT s.job_type, s.source_jobs, c.canonical_jobs,\n  round(toFloat64(c.canonical_jobs) * 100.0 / nullIf(toFloat64(s.source_jobs), 0), 1) AS coverage_pct\nFROM source_counts s\nLEFT JOIN canonical_counts c ON s.job_type = c.job_type",
          "refId": "A"
        }
