          "rawSql": "SELECT ifNull(model_id,'') AS model, ifNull(pipeline,'') AS pipeline, count() AS job_count, round(quantile(0.5)(toFloat64(duration_ms)), 1) AS p50_ms, round(quantile(0.99)(toFloat64(duration_ms)), 1) AS p99_ms, round(countIf(success=1)*100.0/count(), 1) AS success_pct FROM naap.api_ai_batch_jobs WHERE $__timeFilter(completed_at) AND pipeline != '' AND ('${org:csv}' = '__all' OR '${org:csv}' = '' OR has(splitByChar(',', '${org:csv}'), org)) GROUP BY model, pipeline ORDER BY job_count DESC LIMIT 30",
