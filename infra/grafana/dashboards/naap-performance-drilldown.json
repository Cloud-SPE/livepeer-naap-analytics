      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "${clickhouse_ds}"
          },
          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "WITH ens AS (SELECT orch_address AS addr, name AS ens_name FROM naap.serving_latest_orchestrator_state),\ntop_orch AS (\n    SELECT orch_address FROM naap.serving_status_samples\n    WHERE $__timeFilter(sample_ts) AND is_attributed = 1 AND orch_address != ''\n    AND ('${org:csv}' = '__all' OR '${org:csv}' = '' OR has(splitByChar(',', '${org:csv}'), org))\n    GROUP BY orch_address ORDER BY avg(output_fps) DESC LIMIT 8\n)\nSELECT toStartOfInterval(s.sample_ts, INTERVAL 5 MINUTE) AS time,\n    if(ifNull(ens.ens_name, '') != '' AND NOT startsWith(lower(ens.ens_name), '0x'), ens.ens_name, s.orch_address) AS \"Orchestrator ENS\",\n    avg(s.output_fps) AS \"Avg FPS\"\nFROM naap.serving_status_samples s\nLEFT JOIN ens ON ens.addr = s.orch_address\nWHERE $__timeFilter(s.sample_ts) AND s.is_attributed = 1 AND s.orch_address != ''\nAND ('${org:csv}' = '__all' OR '${org:csv}' = '' OR has(splitByChar(',', '${org:csv}'), s.org))\nAND (\n    (('${orchestrator:csv}' = '__all' OR '${orchestrator:csv}' = '') AND s.orch_address GLOBAL IN (SELECT orch_address FROM top_orch))\n    OR ('${orchestrator:csv}' != '__all' AND '${orchestrator:csv}' != '' AND has(splitByChar(',', '${orchestrator:csv}'), s.orch_address))\n)\nGROUP BY time, \"Orchestrator ENS\" ORDER BY time",
          "refId": "A"
        }
      ],
      "title": "FPS Average by Orchestrator (5-min intervals)",
      "type": "timeseries"
