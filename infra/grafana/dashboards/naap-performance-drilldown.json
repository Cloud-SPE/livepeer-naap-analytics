      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "${clickhouse_ds}"
          },
          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "SELECT toStartOfInterval(hour, INTERVAL 1 HOUR) AS time,\n    pipeline,\n    sum(inference_fps_sum) / nullIf(sum(sample_count), 0) AS avg_fps\nFROM naap.serving_fps_hourly\nWHERE $__timeFilter(hour)\nAND ('${org:csv}' = '__all' OR '${org:csv}' = '' OR has(splitByChar(',', '${org:csv}'), org))\nAND ('${orchestrator:csv}' = '__all' OR '${orchestrator:csv}' = '' OR has(splitByChar(',', '${orchestrator:csv}'), orch_address))\nGROUP BY time, pipeline ORDER BY time",
          "refId": "A"
        }
      ],
      "title": "Network FPS by Pipeline (1h avg)",
      "type": "timeseries"
