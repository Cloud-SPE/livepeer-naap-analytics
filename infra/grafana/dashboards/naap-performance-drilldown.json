      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "${clickhouse_ds}"
          },
          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "WITH stream_orch AS (\n    SELECT stream_id, argMax(orch_address, sample_ts) AS orch_address\n    FROM naap.serving_status_samples\n    WHERE $__timeFilter(sample_ts) AND is_attributed = 1\n    AND ('${org:csv}' = '__all' OR '${org:csv}' = '' OR has(splitByChar(',', '${org:csv}'), org))\n    GROUP BY stream_id\n),\ntop_orch AS (\n    SELECT orch_address FROM stream_orch GROUP BY orch_address LIMIT 8\n)\nSELECT w.hour AS time,\n    if(ifNull(o.name, '') != '' AND NOT startsWith(lower(o.name), '0x'), o.name, so.orch_address) AS \"Orchestrator ENS\",\n    sum(w.video_jitter_sum) / nullIf(sum(w.sample_count), 0) AS \"Avg Video Jitter\"\nFROM naap.agg_webrtc_hourly w\nJOIN stream_orch so ON so.stream_id = w.stream_id\nLEFT JOIN naap.serving_latest_orchestrator_state o ON o.orch_address = so.orch_address\nWHERE $__timeFilter(w.hour)\nAND (\n    (('${orchestrator:csv}' = '__all' OR '${orchestrator:csv}' = '') AND so.orch_address GLOBAL IN (SELECT orch_address FROM top_orch))\n    OR ('${orchestrator:csv}' != '__all' AND '${orchestrator:csv}' != '' AND has(splitByChar(',', '${orchestrator:csv}'), so.orch_address))\n)\nGROUP BY time, \"Orchestrator ENS\" ORDER BY time",
          "refId": "A"
        }
      ],
      "title": "Jitter Coefficient by Orchestrator",
      "type": "timeseries"
    },
