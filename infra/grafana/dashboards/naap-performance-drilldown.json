          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "SELECT toStartOfInterval(sample_ts, INTERVAL 1 HOUR) AS time,\n    avg(e2e_latency_ms) / 1000.0 AS avg_e2e_latency_s,\n    quantileTDigest(0.95)(e2e_latency_ms) / 1000.0 AS p95_e2e_latency_s\nFROM naap.serving_status_samples\nWHERE $__timeFilter(sample_ts) AND e2e_latency_ms > 0\nAND ('${org:csv}' = '__all' OR '${org:csv}' = '' OR has(splitByChar(',', '${org:csv}'), org))\nAND ('${orchestrator:csv}' = '__all' OR '${orchestrator:csv}' = '' OR has(splitByChar(',', '${orchestrator:csv}'), orch_address))\nGROUP BY time ORDER BY time",
          "refId": "A"
        }
