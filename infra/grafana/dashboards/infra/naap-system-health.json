          "queryType": "table",
          "rawSql": "WITH raw_days AS (\n    SELECT org, toDate(event_ts) AS event_date\n    FROM naap.accepted_raw_events\n    WHERE toDate(event_ts) < today()\n    AND ('${org:csv}' = '__all' OR '${org:csv}' = '' OR has(splitByChar(',', '${org:csv}'), org))\n    GROUP BY org, event_date\n), repaired_days AS (\n    SELECT org, event_date\n    FROM naap.resolver_backfill_runs\n    WHERE status = 'success'\n    AND ('${org:csv}' = '__all' OR '${org:csv}' = '' OR has(splitByChar(',', '${org:csv}'), org))\n    GROUP BY org, event_date\n), pending AS (\n    SELECT raw_days.org AS org,\n        toString(raw_days.event_date) AS event_date,\n        toUInt64(dateDiff('day', raw_days.event_date, today())) AS age_days,\n        'waiting_for_first_successful_historical_run' AS reason\n    FROM raw_days\n    LEFT JOIN repaired_days USING (org, event_date)\n    WHERE repaired_days.org IS NULL\n)\nSELECT *\nFROM (\n    SELECT org AS \"Org\",\n        event_date AS \"Event Date\",\n        age_days AS \"Age (days)\",\n        reason AS \"Reason\"\n    FROM pending\n    UNION ALL\n    SELECT 'all' AS \"Org\",\n        '' AS \"Event Date\",\n        toUInt64(0) AS \"Age (days)\",\n        'no unrepaired closed historical org-days' AS \"Reason\"\n    WHERE NOT EXISTS (SELECT 1 FROM pending)\n)\nORDER BY \"Age (days)\" DESC, \"Org\" ASC\nLIMIT 100",
