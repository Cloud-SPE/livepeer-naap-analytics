      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "${clickhouse_ds}"
          },
          "editorType": "sql",
          "format": 1,
          "queryType": "sql",
          "rawSql": "SELECT toFloat64(count()) AS value FROM naap.accepted_raw_events WHERE ingested_at >= now() - INTERVAL 15 MINUTE AND ('${org:csv}' = '__all' OR '${org:csv}' = '' OR has(splitByChar(',', '${org:csv}'), org))",
          "refId": "A"
