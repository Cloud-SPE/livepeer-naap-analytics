    {
      "id": 10,
      "title": "Pending Historical Repairs By Day",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 13
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "${clickhouse_ds}"
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "${clickhouse_ds}"
          },
          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "WITH pending AS (\n    SELECT org,\n        toString(event_date) AS event_date,\n        status,\n        reason,\n        toString(first_dirty_at) AS first_dirty,\n        toString(last_dirty_at) AS last_dirty,\n        toUInt64(attempt_count) AS attempts\n    FROM naap.resolver_dirty_partitions FINAL\n    WHERE status IN ('pending', 'failed')\n    AND ('${org:csv}' = '__all' OR '${org:csv}' = '' OR has(splitByChar(',', '${org:csv}'), org))\n)\nSELECT *\nFROM (\n    SELECT org AS \"Org\",\n        event_date AS \"Event Date\",\n        status AS \"Status\",\n        reason AS \"Reason\",\n        first_dirty AS \"First Dirty\",\n        last_dirty AS \"Last Dirty\",\n        attempts AS \"Attempts\"\n    FROM pending\n    UNION ALL\n    SELECT 'all' AS \"Org\",\n        '' AS \"Event Date\",\n        'none' AS \"Status\",\n        'no pending or failed historical repairs' AS \"Reason\",\n        '' AS \"First Dirty\",\n        '' AS \"Last Dirty\",\n        toUInt64(0) AS \"Attempts\"\n    WHERE NOT EXISTS (SELECT 1 FROM pending)\n)\nORDER BY \"Event Date\" ASC, \"Org\" ASC\nLIMIT 100",
          "refId": "A"
        }
      ],
      "options": {
        "cellHeight": "sm",
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "footer": {
              "reducers": []
            },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              }
            ]
          }
        },
        "overrides": []
      }
    },
