            "type": "grafana-clickhouse-datasource",
            "uid": "${clickhouse_ds}"
          },
          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "SELECT toStartOfInterval(event_ts, INTERVAL 1 MINUTE) AS time, event_type AS stage, count() AS events_per_minute FROM naap.accepted_raw_events WHERE $__timeFilter(event_ts) AND ('${org:csv}' = '__all' OR '${org:csv}' = '' OR has(splitByChar(',', '${org:csv}'), org)) GROUP BY time, stage ORDER BY time",
          "refId": "A"
        }
