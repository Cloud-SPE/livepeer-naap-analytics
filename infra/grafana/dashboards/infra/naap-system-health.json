    {
      "id": 8,
      "title": "Resolver Run History (24h)",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "${clickhouse_ds}"
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "${clickhouse_ds}"
          },
          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "SELECT started_at AS \"Started\", ifNull(finished_at, cast(null, 'Nullable(DateTime64(3, \\'UTC\\'))')) AS \"Finished\", mode AS \"Mode\", status AS \"Status\", ifNull(org, 'all') AS \"Org\", rows_processed AS \"Rows Processed\", if(finished_at IS NOT NULL, toUInt64(greatest(dateDiff('second', started_at, finished_at), 0)), cast(null, 'Nullable(UInt64)')) AS \"Elapsed (s)\", if(finished_at IS NOT NULL AND dateDiff('second', started_at, finished_at) > 0, round(toFloat64(rows_processed) / toFloat64(dateDiff('second', started_at, finished_at)), 2), cast(null, 'Nullable(Float64)')) AS \"Rows/s\", mismatch_count AS \"Mismatches\", ifNull(error_summary, '') AS \"Error Summary\" FROM naap.resolver_runs WHERE started_at >= now() - INTERVAL 24 HOUR AND ('${org:csv}' = '__all' OR '${org:csv}' = '' OR has(splitByChar(',', '${org:csv}'), ifNull(org, ''))) ORDER BY started_at DESC LIMIT 100",
          "refId": "A"
        }
      ],
      "options": {
        "cellHeight": "sm",
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "Started"
          }
        ]
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "footer": {
              "reducers": []
            },
            "inspect": false
