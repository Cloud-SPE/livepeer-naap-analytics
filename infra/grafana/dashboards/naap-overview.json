          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "SELECT toStartOfInterval(window_start, INTERVAL 1 HOUR) AS time,\n    sum(greatest(requested_sessions - no_orch_sessions, 0)) AS served_sessions,\n    sum(no_orch_sessions) AS unserved_sessions\nFROM naap.api_network_demand_by_org\nWHERE $__timeFilter(window_start)\nAND ('${org:csv}' = '__all' OR '${org:csv}' = '' OR has(splitByChar(',', '${org:csv}'), org))\nGROUP BY time ORDER BY time",
          "refId": "A"
        }
      ],
