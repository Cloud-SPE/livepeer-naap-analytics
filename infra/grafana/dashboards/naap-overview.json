          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "SELECT toStartOfInterval(hour, INTERVAL 1 HOUR) AS time,\n    sum(started) AS served_sessions,\n    sum(no_orch) AS unserved_sessions\nFROM naap.agg_stream_hourly\nWHERE $__timeFilter(hour)\nAND ('${org:csv}' = '__all' OR '${org:csv}' = '' OR has(splitByChar(',', '${org:csv}'), org))\nGROUP BY time ORDER BY time",
          "refId": "A"
        }
      ],
      "title": "Served vs Unserved Demand (1h)",
