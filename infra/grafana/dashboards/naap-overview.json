          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "WITH ens AS (SELECT orch_address AS addr, name AS ens_name FROM naap.serving_latest_orchestrator_state),\nfps AS (\n    SELECT orch_address, avg(output_fps) AS avg_fps\n    FROM naap.serving_status_samples\n    WHERE $__timeFilter(sample_ts) AND is_attributed = 1 AND orch_address != ''\n    AND ('${org:csv}' = '__all' OR '${org:csv}' = '' OR has(splitByChar(',', '${org:csv}'), org))\n    AND ('${orchestrator:csv}' = '__all' OR '${orchestrator:csv}' = '' OR has(splitByChar(',', '${orchestrator:csv}'), orch_address))\n    GROUP BY orch_address\n)\nSELECT\n    multiIf(\n        ifNull(ens.ens_name, '') != '' AND NOT startsWith(lower(ens.ens_name), '0x'),\n            ens.ens_name,\n        length(fps.orch_address) > 10,\n            concat(substring(fps.orch_address, 1, 6), '\u2026', substring(fps.orch_address, -4)),\n        fps.orch_address\n    ) AS \"Orchestrator\",\n    fps.avg_fps AS \"Avg FPS\"\nFROM fps\nLEFT JOIN ens ON ens.addr = fps.orch_address\nORDER BY \"Avg FPS\" DESC\nLIMIT 10",
          "refId": "A"
