          "editorType": "sql",
          "format": 1,
          "queryType": "sql",
          "rawSql": "SELECT toFloat64(countDistinct(stream_id)) AS value\nFROM naap.serving_status_samples\nWHERE sample_ts >= now() - INTERVAL 15 MINUTE\nAND is_attributed = 1 AND orch_address != ''\nAND ('${org:csv}' = '__all' OR '${org:csv}' = '' OR has(splitByChar(',', '${org:csv}'), org))\nAND ('${orchestrator:csv}' = '__all' OR '${orchestrator:csv}' = '' OR has(splitByChar(',', '${orchestrator:csv}'), orch_address))",
          "refId": "A"
        }
      ],
      "title": "Streams Served (15m)",
      "type": "stat",
      "description": "Distinct streams that sent at least one status sample in the last 15 minutes (throughput metric, not concurrency). See Current Active Streams for point-in-time concurrency."
