      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "${clickhouse_ds}"
          },
          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "WITH ens AS (SELECT eth_address AS addr, name AS ens_name FROM naap.orch_metadata FINAL),\nlatest_per_stream AS (\n    SELECT stream_id, org, orch_address, pipeline,\n        argMax(output_fps, sample_ts) AS latest_output_fps,\n        argMax(state, sample_ts) AS latest_state,\n        max(sample_ts) AS latest_sample_ts\n    FROM naap.agg_stream_status_samples\n    WHERE sample_ts >= now() - INTERVAL 30 MINUTE AND is_attributed = 1\n    GROUP BY stream_id, org, orch_address, pipeline\n)\nSELECT s.stream_id AS \"Stream ID\",\n    if(ifNull(ens.ens_name, '') != '' AND NOT startsWith(lower(ens.ens_name), '0x'), ens.ens_name, s.orch_address) AS \"Orchestrator\",\n    ifNull(s.pipeline, 'unknown') AS \"Pipeline\",\n    round(ifNull(s.latest_output_fps, 0), 2) AS \"FPS\",\n    s.latest_state AS \"State\",\n    toUInt64(greatest(dateDiff('second', s.latest_sample_ts, now()), 0)) AS \"Last Sample Age (s)\"\nFROM latest_per_stream s\nLEFT JOIN ens e ON e.addr = s.orch_address\nWHERE s.latest_sample_ts >= now() - INTERVAL 15 MINUTE\nAND ('${org:csv}' = '__all' OR '${org:csv}' = '' OR has(splitByChar(',', '${org:csv}'), s.org))\nAND ('${orchestrator:csv}' = '__all' OR '${orchestrator:csv}' = '' OR has(splitByChar(',', '${orchestrator:csv}'), s.orch_address))\nORDER BY \"Last Sample Age (s)\" ASC, \"FPS\" DESC\nLIMIT 20",
          "refId": "A"
        }
      ],
      "title": "Current Active Streams",
      "type": "table"
    }
