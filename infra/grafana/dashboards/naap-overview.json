            "desc": true,
            "displayName": "Unserved Sessions"
          }
        ]
      },
      "targets": [
        {
          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "SELECT if(gateway = '', 'unknown_gateway', gateway) AS \"Gateway\",\n    sum(started) AS \"Started Sessions\",\n    sum(no_orch) AS \"Unserved (No Orch)\",\n    sum(orch_swap) AS \"Orch Swaps\",\n    if(sum(started) + sum(no_orch) > 0,\n        toFloat64(sum(no_orch)) / toFloat64(sum(started) + sum(no_orch)), 0.0) AS \"Unmet Rate\"\nFROM naap.agg_stream_hourly\nWHERE $__timeFilter(hour)\nAND ('${org:csv}' = '__all' OR '${org:csv}' = '' OR has(splitByChar(',', '${org:csv}'), org))\nGROUP BY \"Gateway\"\nORDER BY \"Unserved (No Orch)\" DESC",
          "refId": "A"
        }
      ],
      "title": "Gateway Demand/Supply and Health Summary",
      "type": "table"
    },
    {
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "footer": {
              "reducers": []
            },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
