          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "WITH ens AS (SELECT orch_address AS addr, name AS ens_name FROM naap.serving_latest_orchestrator_state),\nstatus_24h AS (\n    SELECT orch_address,\n        ifNull(nullIf(pipeline, ''), 'unknown') AS pipeline,\n        countDistinct(stream_id) AS active_streams,\n        avg(output_fps) AS avg_fps,\n        quantileTDigest(0.95)(output_fps) AS p95_fps,\n        round(avgIf(startup_latency_ms, startup_latency_ms > 0) / 1000.0, 3) AS avg_e2e_latency_s,\n        round(quantileTDigestIf(0.95)(startup_latency_ms, startup_latency_ms > 0) / 1000.0, 3) AS p95_e2e_latency_s\n    FROM naap.serving_status_samples ss\n    JOIN naap.fact_workflow_sessions fws ON ss.canonical_session_key = fws.canonical_session_key\n    WHERE ss.sample_ts >= now() - INTERVAL 24 HOUR AND ss.is_attributed = 1 AND ss.orch_address != ''\n    AND ('${org:csv}' = '__all' OR '${org:csv}' = '' OR has(splitByChar(',', '${org:csv}'), ss.org))\n    AND ('${orchestrator:csv}' = '__all' OR '${orchestrator:csv}' = '' OR has(splitByChar(',', '${orchestrator:csv}'), ss.orch_address))\n    GROUP BY orch_address, pipeline\n)\nSELECT if(ifNull(ens.ens_name, '') != '' AND NOT startsWith(lower(ens.ens_name), '0x'), ens.ens_name, s.orch_address) AS \"Orchestrator\",\n    s.pipeline AS \"Pipeline\",\n    s.active_streams AS \"Active Streams\",\n    round(s.avg_fps, 2) AS \"Avg FPS\",\n    round(s.p95_fps, 2) AS \"P95 FPS\",\n    s.avg_e2e_latency_s AS \"Avg E2E Latency (s)\",\n    s.p95_e2e_latency_s AS \"P95 E2E Latency (s)\"\nFROM status_24h s\nLEFT JOIN ens ON ens.addr = s.orch_address\nORDER BY s.active_streams DESC, s.avg_fps DESC\nLIMIT 20",
          "refId": "A"
        }
      ],
      "title": "Top Orchestrators (24h: Streams, FPS, Latency)",
      "type": "table"
