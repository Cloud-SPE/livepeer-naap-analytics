          "rawSql": "SELECT toFloat64(round(avgIf(avg_startup_latency_ms, avg_startup_latency_ms > 0) / 1000.0, 3)) AS value\nFROM naap.serving_stream_hourly\nWHERE hour >= toStartOfHour(now() - INTERVAL 1 HOUR)\nAND ('${org:csv}' = '__all' OR '${org:csv}' = '' OR has(splitByChar(',', '${org:csv}'), org))",
