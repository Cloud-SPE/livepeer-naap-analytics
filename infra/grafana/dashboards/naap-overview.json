          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "SELECT ifNull(nullIf(pipeline_id, ''), 'unknown_pipeline') AS \"Pipeline\",\n    ifNull(nullIf(gateway, ''), 'unattributed_gateway') AS \"Gateway\",\n    sum(no_orch_sessions) AS \"No Orch Sessions\",\n    sum(requested_sessions) AS \"Requested Sessions\",\n    if(sum(requested_sessions) > 0,\n        toFloat64(sum(no_orch_sessions)) / toFloat64(sum(requested_sessions)), 0.0) AS \"Unmet Demand Rate\"\nFROM naap.api_network_demand_by_org\nWHERE $__timeFilter(window_start)\nAND ('${org:csv}' = '__all' OR '${org:csv}' = '' OR has(splitByChar(',', '${org:csv}'), org))\nGROUP BY ifNull(nullIf(pipeline_id, ''), 'unknown_pipeline'), ifNull(nullIf(gateway, ''), 'unattributed_gateway')\nHAVING sum(no_orch_sessions) > 0\nORDER BY sum(no_orch_sessions) DESC, sum(requested_sessions) DESC\nLIMIT 12",
