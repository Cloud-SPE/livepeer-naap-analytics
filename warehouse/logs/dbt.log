  create or replace view `naap_naap`.`serving_discovery_latency_hourly` 
  
    
  
  
    
    
  as (
    select
    toStartOfHour(event_ts) as hour,
    org,
    orch_address,
    avg(latency_ms) as avg_latency_ms,
    quantile(0.5)(latency_ms) as p50_latency_ms,
    quantile(0.95)(latency_ms) as p95_latency_ms,
    quantile(0.99)(latency_ms) as p99_latency_ms,
    count() as sample_count
from `naap_naap`.`stg_discovery_results`
where latency_ms > 0
group by hour, org, orch_address
    
  )
      
      
