    multiIf(
    toUInt8(cm.matched_snapshot_ts is not null and length(JSONExtractArrayRaw(ifNull(cm.matched_raw_capabilities, '{}'), 'hardware')) > 0 and greatest(b.observed_orch_address_count, b.observed_orch_url_count) <= 1) = 1, 'matched',
    toUInt8(greatest(b.observed_orch_address_count, b.observed_orch_url_count) > 1 and b.swap_count = 0) = 1, 'ambiguous_candidates',
    toUInt8(cm.matched_snapshot_ts is not null and length(JSONExtractArrayRaw(ifNull(cm.matched_raw_capabilities, '{}'), 'hardware')) = 0 and greatest(b.observed_orch_address_count, b.observed_orch_url_count) <= 1) = 1, 'matched_without_hardware',
    toUInt8(cm.matched_snapshot_ts is null and sm.stale_snapshot_ts is not null and coalesce(b.observed_orch_address, b.observed_orch_url, '') != '') = 1, 'stale_candidate',
    'missing_candidate'
) as attribution_reason,
    multiIf(
    toUInt8(cm.matched_snapshot_ts is not null and length(JSONExtractArrayRaw(ifNull(cm.matched_raw_capabilities, '{}'), 'hardware')) > 0 and greatest(b.observed_orch_address_count, b.observed_orch_url_count) <= 1) = 1, 'resolved',
    toUInt8(greatest(b.observed_orch_address_count, b.observed_orch_url_count) > 1 and b.swap_count = 0) = 1, 'ambiguous',
    toUInt8(cm.matched_snapshot_ts is not null and length(JSONExtractArrayRaw(ifNull(cm.matched_raw_capabilities, '{}'), 'hardware')) = 0 and greatest(b.observed_orch_address_count, b.observed_orch_url_count) <= 1) = 1, 'hardware_less',
    toUInt8(cm.matched_snapshot_ts is null and sm.stale_snapshot_ts is not null and coalesce(b.observed_orch_address, b.observed_orch_url, '') != '') = 1, 'stale',
    'unresolved'
) as attribution_status,
