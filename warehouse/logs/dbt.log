  create or replace view `naap`.`stg_stream_trace` 
  
    
  
  
    
    
  as (
    select
    event_id,
    event_ts,
    org,
    gateway,
    stream_id,
    request_id,
    multiIf(
    nullIf(stream_id, '') IS NOT NULL AND nullIf(request_id, '') IS NOT NULL,
    concat(stream_id, '|', request_id),
    nullIf(stream_id, '') IS NOT NULL,
    concat(stream_id, '|_missing_request'),
    nullIf(request_id, '') IS NOT NULL,
    concat('_missing_stream|', request_id),
    ''
) as canonical_session_key,
    trace_type,
    raw_pipeline_hint,
    pipeline_id,
    orch_raw_address,
    orch_url,
    message,
    data
from naap.typed_stream_trace final
where event_id != ''
    
  )
      
      
