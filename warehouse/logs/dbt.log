with mv_sources as (
      -- Find all MVs and their target tables (database and name of the MV, plus the SELECT SQL)
      select
        name as mv_name,
        database as mv_database,
        any(as_select) as mv_sql,
        any(replaceRegexpOne(create_table_query, '.*TO\\s+`?([^`\\s(]+)`?\\.`?([^`\\s(]+)`?.*', '\\1.\\2')) as target_fqn
      
