# deploy/infra2/.env.example
#
# Environment variable reference for all naap infra2 stacks.
# Copy this to each stack's Portainer "Environment variables" section,
# filling in the required values.
#
# DO NOT commit real passwords. This file contains only placeholders.

# ═══════════════════════════════════════════════════════════════════════════════
# naap-kafka stack
# ═══════════════════════════════════════════════════════════════════════════════

# Password for the naap-monitor Kafka SCRAM user (used by kafka-exporter).
# Must match the password set during SCRAM user creation.
KAFKA_MONITOR_PASSWORD=change-me-strong-password

# Optional
KAFKA_LOG_RETENTION_HOURS=168

# ═══════════════════════════════════════════════════════════════════════════════
# naap-clickhouse stack
# ═══════════════════════════════════════════════════════════════════════════════

# ClickHouse internal user passwords — set these to strong unique values.
CLICKHOUSE_ADMIN_PASSWORD=change-me-strong-password
CLICKHOUSE_WRITER_PASSWORD=change-me-strong-password
CLICKHOUSE_READER_PASSWORD=change-me-strong-password

# Password for the naap-consumer Kafka SCRAM user.
# Must match the password set during SCRAM user creation.
NAAP_CONSUMER_PASSWORD=change-me-strong-password

# Optional — Kafka Engine consumer groups (must be unique per deployment node)
KAFKA_BROKER_LIST=naap-kafka:9092
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_NETWORK_GROUP=clickhouse-naap-network
KAFKA_STREAMING_GROUP=clickhouse-naap-streaming

# Optional — image tag
IMAGE_TAG=latest

# ═══════════════════════════════════════════════════════════════════════════════
# naap-app stack
# ═══════════════════════════════════════════════════════════════════════════════

# Shared with naap-clickhouse — same values
CLICKHOUSE_READER_PASSWORD=change-me-strong-password
CLICKHOUSE_WRITER_PASSWORD=change-me-strong-password

# Optional
IMAGE_TAG=latest
RATE_LIMIT_RPS=100
RATE_LIMIT_BURST=200
LOG_LEVEL=info
ENRICHMENT_ENABLED=true
ENRICHMENT_INTERVAL=5m
LIVEPEER_API_URL=https://livepeer-api.livepeer.cloud
OTLP_ENDPOINT=

# ═══════════════════════════════════════════════════════════════════════════════
# naap-grafana stack
# ═══════════════════════════════════════════════════════════════════════════════

# Grafana web admin credentials
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=change-me-strong-password

# ClickHouse datasource password — shared with naap-clickhouse / naap-app
CLICKHOUSE_READER_PASSWORD=change-me-strong-password

# ═══════════════════════════════════════════════════════════════════════════════
# naap-kafka-ui stack
# ═══════════════════════════════════════════════════════════════════════════════

# Kafka UI web login password
KAFKA_UI_ADMIN_USER=admin
KAFKA_UI_ADMIN_PASSWORD=change-me-strong-password

# Password for the kafka-ui Kafka SCRAM user.
# Must match the password set during SCRAM user creation.
KAFKA_UI_SASL_PASSWORD=change-me-strong-password

# ═══════════════════════════════════════════════════════════════════════════════
# naap-prometheus stack
# ═══════════════════════════════════════════════════════════════════════════════

# No environment variables required.

# ═══════════════════════════════════════════════════════════════════════════════
# naap-mirrormaker2 stack
# ═══════════════════════════════════════════════════════════════════════════════

# Password for the mm2-connector Kafka SCRAM user (infra2 local broker auth).
# Must match the password set during SCRAM user creation.
MM2_CONNECTOR_PASSWORD=change-me-strong-password

# Password for the cloudspe Kafka SCRAM user (Cloud SPE gateway producers).
# Distribute this credential to all Cloud SPE gateways for streaming_events ingestion.
# Must match the password set during SCRAM user creation.
CLOUDSPE_PRODUCER_PASSWORD=change-me-strong-password

# Daydream / Confluent Cloud credentials (API key + secret from Confluent Cloud console)
DAYDREAM_SASL_USERNAME=YOUR_CONFLUENT_API_KEY
DAYDREAM_SASL_PASSWORD=YOUR_CONFLUENT_API_SECRET

# Optional — override broker addresses if they change
# DAYDREAM_BOOTSTRAP_SERVERS=pkc-921jm.us-east-2.aws.confluent.cloud:9092
# INFRA2_BOOTSTRAP_SERVERS=naap-kafka:9092
