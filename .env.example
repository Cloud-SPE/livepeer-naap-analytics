# Environment configuration template.
# Copy to .env and fill in real values. Never commit .env to git.

# ── Environment ───────────────────────────────────────────────────────────────
ENV=development
LOG_LEVEL=debug

# ── API ───────────────────────────────────────────────────────────────────────
PORT=8000
RATE_LIMIT_RPS=30
RATE_LIMIT_BURST=60

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_NETWORK_GROUP=clickhouse-naap-network
KAFKA_STREAMING_GROUP=clickhouse-naap-streaming

# ── ClickHouse ─────────────────────────────────────────────────────────────────
# Admin password for the naap_admin user (created by docker-compose).
CLICKHOUSE_ADMIN_PASSWORD=changeme
# Application user credentials (created by migration 001).
CLICKHOUSE_WRITER_PASSWORD=naap_writer_changeme
CLICKHOUSE_READER_PASSWORD=naap_reader_changeme
# Schema mode: bootstrap = apply full schema on fresh volume; migrations = apply forward migrations on existing data.
CLICKHOUSE_SCHEMA_MODE=bootstrap
# Kafka broker consumed by ClickHouse Kafka engine tables.
# Set to 'kafka:29092' to use the local Kafka container instead of production.
KAFKA_BROKER_LIST=infra2.cloudspe.com:9092
# Offset policy for ClickHouse Kafka consumers on first connect to a broker.
# earliest = consume full topic history | latest = new messages only.
KAFKA_AUTO_OFFSET_RESET=earliest
# SASL credentials for ClickHouse Kafka Engine (leave empty for plaintext/local Kafka).
KAFKA_SECURITY_PROTOCOL=
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# ── Resolver ──────────────────────────────────────────────────────────────────
# Long-lived background service that publishes corrected state into canonical_*_store and api_*_store.
RESOLVER_ENABLED=true
# Run mode: auto (bootstrap + same-day auto-heal + tail), bootstrap (one-shot), tail (continuous), repair-window (bounded replay).
RESOLVER_MODE=auto
RESOLVER_INTERVAL=1m
RESOLVER_LATENESS_WINDOW=10m
RESOLVER_DIRTY_QUIET_PERIOD=2m
RESOLVER_CLAIM_TTL=2m
RESOLVER_VERSION=selection-centered-v1
RESOLVER_BATCH_SIZE=500
RESOLVER_PORT=9102
# Bearer token for the resolver's internal repair-request API on /internal/v1/*.
RESOLVER_ADMIN_TOKEN=

# ── Enrichment ────────────────────────────────────────────────────────────────
# Periodic fetch of orchestrator/gateway metadata (ENS names, stake, etc.) from the Livepeer API.
ENRICHMENT_ENABLED=true
ENRICHMENT_INTERVAL=5m
LIVEPEER_API_URL=https://livepeer-api.livepeer.cloud

# ── Grafana Alerting (optional) ───────────────────────────────────────────────
# Grafana alerting is rendered from infra/grafana/provisioning/alerting/.
# If alerting is enabled, every enabled channel must also provide its secret.
GRAFANA_ALERTING_ENABLED=false
GRAFANA_PUBLIC_URL=https://grafana.livepeer.cloud/
GRAFANA_ALERT_DISCORD_ENABLED=false
GRAFANA_ALERT_DISCORD_WEBHOOK_URL=
GRAFANA_ALERT_TELEGRAM_ENABLED=false
GRAFANA_ALERT_TELEGRAM_BOT_TOKEN=
GRAFANA_ALERT_TELEGRAM_CHAT_ID=

# ── MCP ClickHouse ────────────────────────────────────────────────────────────
# Bearer token required by MCP clients to authenticate against the MCP server.
# Generate with: openssl rand -hex 32
MCP_AUTH_TOKEN=
# Public hostname for the MCP server (e.g. mcp.cloudspe.com).
MCP_DOMAIN=

# ── Build / Deploy ─────────────────────────────────────────────────────────────
# Docker image tag used by `make push` and production stack files.
IMAGE_TAG=latest
