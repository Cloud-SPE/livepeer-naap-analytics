# Environment configuration template.
# Copy to .env and fill in real values. Never commit .env to git.

# ── Environment ───────────────────────────────────────────────────────────────
ENV=development
LOG_LEVEL=debug

# ── API ───────────────────────────────────────────────────────────────────────
PORT=8000

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=naap-analytics-pipeline
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_DIAL_TIMEOUT=10s
KAFKA_READ_TIMEOUT=10s
KAFKA_WRITE_TIMEOUT=10s

# ── ClickHouse ─────────────────────────────────────────────────────────────────
# Admin password for the naap_admin user (created by docker-compose).
CLICKHOUSE_ADMIN_PASSWORD=changeme
# Application user credentials (created by migration 001).
CLICKHOUSE_WRITER_PASSWORD=naap_writer_changeme
CLICKHOUSE_READER_PASSWORD=naap_reader_changeme
# Kafka broker consumed by ClickHouse Kafka engine tables.
# Set to 'kafka:29092' to use the local Kafka container instead of production.
KAFKA_BROKER_LIST=infra2.cloudspe.com:9092
# Offset policy for ClickHouse Kafka consumers on first connect to a broker.
# earliest = consume full topic history | latest = new messages only.
KAFKA_AUTO_OFFSET_RESET=earliest

# ── Enrichment ────────────────────────────────────────────────────────────────
# Periodic fetch of orchestrator/gateway metadata (ENS names, stake, etc.) from the Livepeer API.
ENRICHMENT_ENABLED=true
ENRICHMENT_INTERVAL=5m
LIVEPEER_API_URL=https://livepeer-api.livepeer.cloud

# ── Telemetry (optional) ──────────────────────────────────────────────────────
# Set to an OTLP-compatible endpoint (e.g., Jaeger, Honeycomb, Grafana Tempo).
# Leave empty to disable OTLP export (console output in development mode).
OTLP_ENDPOINT=
